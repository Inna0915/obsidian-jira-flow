{
  "name": "obsidian-jira-flow",
  "version": "2.1.2",
  "description": "Jira-Flow plugin for Obsidian - Kanban board with Jira sync and daily logging",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "css": "npx tailwindcss -i ./src/styles/tailwind.css -o ./styles.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "obsidian",
    "jira",
    "kanban"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.12",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "html-react-parser": "^5.2.17",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
